# OpenRouter API key - powers both the Shorts script generator
# (lib/generator.ts) and the AI scene images used by the video pipeline
# (lib/video/images.ts). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default text model (defaults to openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: override the default image model (defaults to google/gemini-2.5-flash-image)
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# --- "Videoya Dönüştür" (script -> vertical AI video) ---

# ElevenLabs: text-to-speech voiceover per segment. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional overrides:
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Image-to-video backend: turns each AI scene image into a short animated
# clip. Three providers are supported (lib/video/video-provider.ts); you
# don't need to configure any of them explicitly - if none of DASHSCOPE_API_KEY
# / RUNWAYML_API_SECRET are set, it automatically falls back to OpenRouter
# using the OPENROUTER_API_KEY above (zero extra setup, but pricier per
# second). Priority when multiple are set: Wan > Runway > OpenRouter -
# override with VIDEO_PROVIDER.

# Wan 2.6 Flash (Alibaba Cloud / DashScope) - "ucuz Çinli alternatif":
# ~$0.025/sec at 720p, the cheapest option but needs its own account. Sign up
# (international/Singapore region) at https://bailian.console.alibabacloud.com
# and create a Model Studio API key: https://www.alibabacloud.com/help/en/model-studio/get-api-key
DASHSCOPE_API_KEY=
# Optional overrides:
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
# DASHSCOPE_VIDEO_MODEL=wan2.6-i2v-flash

# Runway Gen-4 Turbo - ~$0.05/sec, the original integration. https://dev.runwayml.com
RUNWAYML_API_SECRET=
# Optional overrides:
# RUNWAY_MODEL=gen4_turbo
# RUNWAY_RATIO=720:1280

# Optional: override the OpenRouter video model used for the no-extra-setup
# fallback (defaults to kwaivgi/kling-v3.0-std, ~$0.084/sec, China/Kuaishou).
# Full model list: https://openrouter.ai/api/v1/videos/models
# OPENROUTER_VIDEO_MODEL=kwaivgi/kling-v3.0-std

# Optional: force a specific image-to-video provider ("wan", "runway", or
# "openrouter"). Without this, the priority above is used automatically.
# VIDEO_PROVIDER=wan

# Optional: how many segments to process at once during rendering (defaults
# to 2). Keep this low - ElevenLabs free/starter tiers cap concurrent
# requests at 2-3; raise it only if your plan supports more.
# VIDEO_PIPELINE_CONCURRENCY=2

# Optional: Vercel Blob storage for the final rendered mp4 (recommended on
# Vercel, since serverless functions don't have a persistent filesystem).
# Without this, videos are written to public/generated-shorts/ instead,
# which only works for local dev / a traditional long-running Node server.
# BLOB_READ_WRITE_TOKEN=

# Optional: your deployed URL, sent as HTTP-Referer to OpenRouter for their
# leaderboard/analytics. Not required for the feature to work.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
