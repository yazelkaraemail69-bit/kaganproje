# Sunucu (yerel)
PORT=4000

# OpenRouter (https://openrouter.ai/keys) — Vercel'de Environment Variables olarak ekleyin
OPENROUTER_API_KEY=sk-or-v1-BURAYA-GERCEK-ANAHTARINIZI-YAZIN

# OpenRouter istek basliklari (opsiyonel)
OPENROUTER_SITE_URL=https://el-yazisi-cevirmen.vercel.app
OPENROUTER_APP_NAME=El Yazisi Cevirmen

# Web arayuzu / mobil ile paylasilan sir (guclu bir deger kullanin)
APP_SHARED_SECRET=change-this-to-a-long-random-string

# CORS (Vercel icin * veya kendi domaininiz)
CORS_ORIGINS=*
