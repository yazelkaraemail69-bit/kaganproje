# Sunucu
PORT=4000

# OpenRouter (https://openrouter.ai/keys) - ASLA mobil uygulamaya veya git'e gomulmez
# Asagidaki ornek deger CALISMAZ. Kendi anahtarinizi yazin:
OPENROUTER_API_KEY=sk-or-v1-BURAYA-GERCEK-ANAHTARINIZI-YAZIN

# OpenRouter istek basliklari icin (opsiyonel ama onerilir)
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=El Yazisi Cevirmen

# Mobil uygulama ile backend arasindaki basit paylasilan-sir kontrolu.
# NOT: Bu, gercek bir kullanici kimlik dogrulamasi degildir; sadece
# rastgele botlarin/scraperlarin ucnoktalari kullanmasini zorlastirir.
# Gercek kullanici hesaplari gerekirse JWT tabanli bir auth katmanina
# gecilmesi onerilir.
APP_SHARED_SECRET=change-this-to-a-long-random-string

# --- UCRETLI MODELLER ---
# Istemci, asagidaki 5 model arasindan birini secer (backend/src/config/paidModels.ts).
# Varsayilan: google/gemini-2.5-flash
# CORS icin izin verilen originler (virgulle ayrilmis). Sadece backend'e
# tarayicidan istek atilacaksa gereklidir; mobil uygulama icin zorunlu degildir.
CORS_ORIGINS=*
